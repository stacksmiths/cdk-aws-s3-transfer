{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CDK App",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/cdk",
      "args": ["synth"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Tests",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/venv/bin/pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "CDK Deploy",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/cdk",
      "args": ["deploy"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
